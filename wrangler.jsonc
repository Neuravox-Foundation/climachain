{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "climachain",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "climachain.online", "custom_domain": true },
    { "pattern": "www.climachain.online", "custom_domain": true }
  ],
  "kv_namespaces": [
    {
      "binding": "NDVI_KV",
      "id": "c4d63bcf211348ef8dda265b92857399"
    },
    // Pilot action-workflow store (UNICEF Yobe pilot).
    {
      "binding": "PILOT_KV",
      "id": "6a7b0579f0f64ceab8a5e9f38bba3715"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_APP_NAME": "ClimaChain"
  }
  // Set sensitive values via:
  //   npx wrangler secret put DEEPSEEK_API_KEY
  //   npx wrangler secret put CDSE_CLIENT_ID
  //   npx wrangler secret put CDSE_CLIENT_SECRET
  // For local dev, copy .dev.vars.example to .dev.vars
}
